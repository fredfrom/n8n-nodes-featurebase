{
	"name": "n8n-nodes-featurebase",
	"version": "0.1.2",
	"description": "n8n community node for Featurebase — product feedback, changelogs, and roadmaps",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"featurebase",
		"feedback",
		"changelog",
		"roadmap"
	],
	"license": "MIT",
	"author": {
		"name": "Friedemann Frommelt",
		"email": "friedemannfrommelt1996@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/fredfrom/n8n-nodes-featurebase.git"
	},
	"main": "index.js",
	"scripts": {
		"build": "tsc && gulp build:icons",
		"dev": "tsc --watch",
		"format": "prettier nodes credentials --write",
		"lint": "eslint nodes credentials package.json --ext .ts",
		"lintfix": "eslint nodes credentials package.json --ext .ts --fix",
		"prepublishOnly": "npm run build",
		"test": "jest"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/FeaturebaseApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Featurebase/Featurebase.node.js",
			"dist/nodes/Featurebase/FeaturebaseTrigger.node.js"
		]
	},
	"devDependencies": {
		"@types/jest": "^30.0.0",
		"@types/node": "^25.5.0",
		"@typescript-eslint/eslint-plugin": "^7.0.0",
		"@typescript-eslint/parser": "^7.0.0",
		"eslint": "^8.56.0",
		"eslint-plugin-n8n-nodes-base": "^1.16.2",
		"gulp": "^4.0.2",
		"jest": "^30.3.0",
		"n8n-workflow": "^1.0.0",
		"prettier": "^3.2.0",
		"ts-jest": "^29.4.6",
		"typescript": "^5.3.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
